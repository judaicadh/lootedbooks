---
import Base from '../../layouts/Base.astro';
import { SOURCES, SOURCE_CATS } from '../../data/looted';

const pillStyle = (active: boolean) =>
  `appearance:none;cursor:pointer;background:${active ? 'var(--ink)' : 'none'};color:${active ? 'var(--pp)' : 'var(--ink2)'};border:1px solid ${active ? 'var(--ink)' : 'rgba(var(--inkrgb),.22)'};border-radius:20px;padding:6px 13px;font:400 12px/1 var(--sans)`;
---
<Base title="Sources & databases — Nazi Looted Books" crumb="/sources/" active="sources">
  <h1 style="margin:14px 0 0;font:400 33px/1.05 var(--display);text-transform:uppercase;letter-spacing:.02em">Sources &amp; databases</h1>
  <p style="margin:16px 0 0;max-width:660px;font:400 16.5px/1.55 var(--serif);color:var(--mut)">The record only holds because it points outward. These are the sources Bruce Nielsen reasons against — the exact resources cited in his essay, linked. Filter by the question they help answer.</p>

  <div data-src-filters style="margin-top:26px;display:flex;gap:10px;flex-wrap:wrap">
    {SOURCE_CATS.map((c) => (
      <button type="button" data-cat={c} style={pillStyle(c === 'all')}>{c === 'all' ? 'all sources' : c}</button>
    ))}
  </div>

  <div data-src-grid style="margin-top:22px;display:grid;grid-template-columns:1fr 1fr;gap:16px">
    {SOURCES.map((s) => (
      <div data-type={s.type} style="background:var(--sf);border:1px solid rgba(var(--inkrgb),.14);border-radius:4px;padding:18px 20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px">
          {s.url ? (
            <a href={s.url} target="_blank" rel="noopener noreferrer" style="font:500 15.5px/1.35 var(--sans);color:var(--ac)">{s.name} ↗</a>
          ) : (
            <div style="font:500 15.5px/1.35 var(--sans);color:var(--ink)">{s.name}</div>
          )}
          <span style="font:400 10px/1 'IBM Plex Mono',monospace;color:var(--fn);white-space:nowrap">{s.type}</span>
        </div>
        <div style="margin-top:8px;font:400 13.5px/1.5 var(--serif);color:var(--mut)">Answers: {s.question}</div>
        <div style="margin-top:6px;font:400 11.5px/1 'IBM Plex Mono',monospace;color:var(--fn)">{s.region}{s.url ? '' : ' · not online'}</div>
      </div>
    ))}
  </div>
</Base>

<script is:inline>
  (function () {
    const filters = document.querySelector('[data-src-filters]');
    const grid = document.querySelector('[data-src-grid]');
    if (!filters || !grid) return;
    const btns = filters.querySelectorAll('[data-cat]');
    const cards = grid.querySelectorAll('[data-type]');
    const active = 'background:var(--ink);color:var(--pp);border:1px solid var(--ink)';
    const idle = 'background:none;color:var(--ink2);border:1px solid rgba(var(--inkrgb),.22)';
    const base = 'appearance:none;cursor:pointer;border-radius:20px;padding:6px 13px;font:400 12px/1 var(--sans);';
    btns.forEach((b) => b.addEventListener('click', () => {
      const cat = b.getAttribute('data-cat');
      btns.forEach((x) => x.setAttribute('style', base + (x === b ? active : idle)));
      cards.forEach((c) => {
        c.style.display = (cat === 'all' || c.getAttribute('data-type') === cat) ? '' : 'none';
      });
    }));
  })();
</script>
