---
import Base from '../../layouts/Base.astro';
import { urls, OWNERS, RECORDS, FEATURED } from '../../data/looted';

export function getStaticPaths() {
  return Object.values(OWNERS).map((o) => ({ params: { slug: o.slug }, props: { owner: o } }));
}

const { owner } = Astro.props;
const books = owner.bookIds.map((id) => {
  const b = RECORDS.find((x) => x.id === id) || FEATURED[id];
  return { id, title: b ? b.title : id };
});
---
<Base title={`${owner.name} — former owner`} crumb={`/owners/${owner.slug}/`} active="register">
  <div style="max-width:760px">
    <a href={urls.register} style="font:400 12.5px/1 var(--sans);color:var(--ac)">← The register</a>

    <div style="margin-top:16px;display:grid;grid-template-columns:1fr 220px;gap:36px;align-items:start">
      <div>
        <div style="font:400 11px/1 'IBM Plex Mono',monospace;color:var(--fn)">Former owner</div>
        <h1 style="margin:8px 0 0;font:400 32px/1.2 var(--serif);letter-spacing:-.01em">{owner.name}</h1>
        <p style="margin:14px 0 0;font:400 16.5px/1.6 var(--serif);color:var(--ink)">{owner.bio}</p>

        <div style="margin-top:20px;padding:14px 16px;background:var(--sf);border:1px solid rgba(var(--inkrgb),.14);border-radius:4px">
          <div style="font:500 10.5px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--fn)">In the victim databases</div>
          <div style="margin-top:8px;font:400 14.5px/1.4 var(--serif);color:var(--ink)">{owner.dbNote} <span style="color:var(--ac)">↗</span></div>
        </div>

        <div style="margin-top:26px;font:500 11px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--mut)">Their books at Penn</div>
        {books.length > 0 ? (
          <div style="margin-top:12px;border-top:1px solid rgba(var(--inkrgb),.14)">
            {books.map((b) => (
              <a href={urls.record(b.id)} style="text-decoration:none;border-bottom:1px solid rgba(var(--inkrgb),.12);padding:13px 4px;display:flex;justify-content:space-between;gap:16px;align-items:baseline">
                <span style="font:400 15px/1.35 var(--serif);color:var(--ink)">{b.title}</span>
                <span style="font:400 16px/1 var(--serif);color:var(--ac)">→</span>
              </a>
            ))}
          </div>
        ) : (
          <p style="margin:12px 0 0;font:400 14.5px/1.6 var(--serif);font-style:italic;color:var(--mut)">Their individual volumes are still being linked into the register; the grouping is recorded on the Lithuanian sheet.</p>
        )}
      </div>

      <aside>
        <div style="height:200px;border:1px solid rgba(var(--inkrgb),.16);border-radius:3px;background-image:repeating-linear-gradient(-45deg,#eae5da,#eae5da 8px,#f2eee5 8px,#f2eee5 16px);display:flex;align-items:flex-end;padding:12px">
          <span style="font:400 10.5px/1.5 'IBM Plex Mono',monospace;color:var(--fn3)">their ownership<br>stamp — photograph</span>
        </div>
      </aside>
    </div>
  </div>
</Base>
